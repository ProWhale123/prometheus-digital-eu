---
/* src/components/PageTransition.astro - Hybrid: GSAP cover + CSS reveal */
---
<div
    id="pt-overlay-text"
    class="fixed inset-0 z-[9995] flex items-center justify-center pointer-events-none pt-text-initial"
>
    <h2 class="text-2xl md:text-4xl font-black uppercase tracking-[0.2em] text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300">
        Prometheus Digital
    </h2>
</div>

<!-- Primary curtain: solid dark -->
<div class="pt-curtain fixed inset-0 z-[9992] pointer-events-none pt-curtain-initial">
    <div class="absolute inset-0 bg-[#0B1120]"></div>
    <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-sky-400/60 to-transparent"></div>
</div>

<!-- Secondary curtain: slightly lighter for depth stagger -->
<div class="pt-curtain fixed inset-0 z-[9991] bg-[#0f1729] pointer-events-none pt-curtain-initial pt-curtain-stagger"></div>

<script>
    import { gsap } from "gsap";

    function getCurtains() { return document.querySelectorAll('.pt-curtain'); }
    function getText() { return document.getElementById('pt-overlay-text'); }

    // --- 1. COVER: GSAP (no competing JS during cover phase) ---
    document.addEventListener('astro:before-preparation', (event) => {
        const curtains = getCurtains();
        const text = getText();
        if (curtains.length === 0 || !text) return;

        const originalLoader = event.loader;
        event.loader = async () => {
            // Remove initial state classes, add covering classes
            curtains.forEach(c => {
                c.classList.remove('pt-curtain-initial', 'pt-curtain-reveal');
                c.classList.add('pt-curtain-cover');
            });
            text.classList.remove('pt-text-initial', 'pt-text-reveal');
            text.classList.add('pt-text-cover');

            // Wait for CSS cover animation + page fetch
            await Promise.all([
                new Promise(r => setTimeout(r, 700)),
                originalLoader()
            ]);
        };
    });

    // --- 2. REVEAL: CSS transitions (compositor thread, immune to main thread blocking) ---
    document.addEventListener('astro:after-swap', () => {
        const curtains = getCurtains();
        const text = getText();
        if (curtains.length === 0 || !text) return;

        // Ensure covering state (no transition for instant set)
        curtains.forEach(c => {
            c.classList.remove('pt-curtain-initial', 'pt-curtain-reveal');
            c.classList.add('pt-curtain-cover');
            (c as HTMLElement).style.transition = 'none';
        });
        text.classList.remove('pt-text-initial', 'pt-text-reveal');
        text.classList.add('pt-text-cover');
        (text as HTMLElement).style.transition = 'none';

        // Force reflow so the instant set takes effect
        curtains[0] && (curtains[0] as HTMLElement).offsetHeight;

        // Now trigger reveal via CSS (runs on compositor, won't stutter)
        requestAnimationFrame(() => {
            curtains.forEach(c => {
                (c as HTMLElement).style.transition = '';
                c.classList.remove('pt-curtain-cover');
                c.classList.add('pt-curtain-reveal');
            });
            (text as HTMLElement).style.transition = '';
            text.classList.remove('pt-text-cover');
            text.classList.add('pt-text-reveal');

            // Reset to initial after animation
            setTimeout(() => {
                curtains.forEach(c => {
                    c.classList.remove('pt-curtain-reveal');
                    c.classList.add('pt-curtain-initial');
                    (c as HTMLElement).style.transition = 'none';
                });
                text.classList.remove('pt-text-reveal');
                text.classList.add('pt-text-initial');
                (text as HTMLElement).style.transition = 'none';
            }, 750);
        });
    });
</script>

<style>
    /* Initial: hidden below viewport */
    .pt-curtain-initial {
        transform: translateY(100%);
    }

    /* Cover: slide up to cover viewport */
    .pt-curtain-cover {
        transform: translateY(0%);
        transition: transform 0.65s cubic-bezier(0.76, 0, 0.24, 1);
    }
    .pt-curtain-stagger.pt-curtain-cover {
        transition-delay: 0.06s;
    }

    /* Reveal: slide away upward — CSS compositor thread, immune to JS blocking */
    .pt-curtain-reveal {
        transform: translateY(-100%);
        transition: transform 0.6s cubic-bezier(0.76, 0, 0.24, 1);
    }
    .pt-curtain-stagger.pt-curtain-reveal {
        transition-delay: 0.06s;
    }

    /* Text states */
    .pt-text-initial {
        opacity: 0;
        transform: translateY(2rem) scale(0.92);
        filter: blur(8px);
    }

    .pt-text-cover {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0px);
        transition: opacity 0.5s ease-out 0.2s,
                    transform 0.5s ease-out 0.2s,
                    filter 0.5s ease-out 0.2s;
    }

    .pt-text-reveal {
        opacity: 0;
        transform: translateY(-1.5rem) scale(0.95);
        filter: blur(6px);
        transition: opacity 0.35s ease-in,
                    transform 0.35s ease-in,
                    filter 0.35s ease-in;
    }
</style>
