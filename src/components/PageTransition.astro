---
/* src/components/PageTransition.astro - Premium 2-curtain with GSAP */
---
<div
    id="pt-overlay-text"
    class="fixed inset-0 z-[9995] flex items-center justify-center pointer-events-none"
    style="opacity:0;transform:translateY(2rem) scale(0.92);filter:blur(8px)"
>
    <h2 class="text-2xl md:text-4xl font-black uppercase tracking-[0.2em] text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300">
        Prometheus Digital
    </h2>
</div>

<!-- Primary curtain: solid dark -->
<div class="pt-curtain fixed inset-0 z-[9992] pointer-events-none" style="transform:translateY(100%)">
    <div class="absolute inset-0 bg-[#0B1120]"></div>
    <!-- Subtle gradient shimmer on top edge -->
    <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-sky-400/60 to-transparent"></div>
</div>

<!-- Secondary curtain: slightly lighter for depth stagger -->
<div class="pt-curtain fixed inset-0 z-[9991] bg-[#0f1729] pointer-events-none" style="transform:translateY(100%)"></div>

<script>
    import { gsap } from "gsap";

    // Query elements fresh each time — after view transitions, old refs are detached
    function getCurtains() { return document.querySelectorAll('.pt-curtain'); }
    function getText() { return document.getElementById('pt-overlay-text'); }

    // --- 1. COVER (on click: curtains slide up + branded text) ---
    document.addEventListener('astro:before-preparation', (event) => {
        const curtains = getCurtains();
        const text = getText();
        if (curtains.length === 0 || !text) return;

        const originalLoader = event.loader;
        event.loader = async () => {
            // Proper Promise wrapping — GSAP thenables can be unreliable in Promise.all
            const animDone = new Promise<void>(resolve => {
                const tl = gsap.timeline({ onComplete: resolve });

                tl.to(curtains, {
                    y: '0%',
                    duration: 0.65,
                    ease: "power4.inOut",
                    stagger: 0.06
                }, 0)
                .to(text, {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    filter: 'blur(0px)',
                    duration: 0.5,
                    ease: "power2.out"
                }, 0.25);
            });

            // Run animation and page fetch in parallel, proceed when both done
            await Promise.all([animDone, originalLoader()]);

            // Ensure curtain is fully covering before swap (in case of race)
            gsap.set(curtains, { y: '0%' });
        };
    });

    // --- 2. REVEAL (after swap: curtains slide away) ---
    document.addEventListener('astro:after-swap', () => {
        const curtains = getCurtains();
        const text = getText();
        if (curtains.length === 0 || !text) return;

        // Instant reset: curtains covering, text visible
        gsap.set(curtains, { y: '0%' });
        gsap.set(text, { opacity: 1, y: 0, scale: 1, filter: 'blur(0px)' });

        // Use requestAnimationFrame to avoid conflict with component init scripts
        // (ScrollTrigger.refresh() from FloatingElement can block the main thread)
        requestAnimationFrame(() => {
            const tl = gsap.timeline({
                onComplete: () => {
                    gsap.set(curtains, { y: '100%' });
                    gsap.set(text, { opacity: 0, y: 32, scale: 0.92, filter: 'blur(8px)' });
                }
            });

            // Text blurs out and scales down
            tl.to(text, {
                opacity: 0,
                y: -24,
                scale: 0.95,
                filter: 'blur(6px)',
                duration: 0.3,
                ease: "power2.in"
            }, 0)

            // Curtains slide away with stagger
            .to(curtains, {
                y: '-100%',
                duration: 0.55,
                ease: "power4.inOut",
                stagger: 0.06
            }, 0.05);
        });
    });
</script>

<style>
    .pt-curtain {
        will-change: auto; /* Only promote to GPU layer during animation, not permanently */
    }
</style>
