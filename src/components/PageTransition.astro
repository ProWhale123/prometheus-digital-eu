---
/* src/components/PageTransition.astro - Lightweight single-curtain version */
---
<div
    id="pt-overlay-text"
    class="fixed inset-0 z-[9995] flex items-center justify-center pointer-events-none"
    style="opacity:0;transform:translateY(2rem)"
>
    <h2 class="text-2xl md:text-4xl font-black uppercase tracking-[0.2em] text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300">
        Prometheus Digital
    </h2>
</div>

<div id="pt-curtain" class="fixed inset-0 z-[9992] bg-[#0B1120] pointer-events-none" style="transform:translateY(100%)"></div>

<script>
    const curtain = document.getElementById('pt-curtain')!;
    const text = document.getElementById('pt-overlay-text')!;

    // CSS transitions handle the GPU compositing — no GSAP needed for curtain
    curtain.style.transition = 'none';
    text.style.transition = 'none';

    // --- 1. COVER (on click: curtain slides up) ---
    document.addEventListener('astro:before-preparation', (event) => {
        if (!curtain || !text) return;

        const originalLoader = event.loader;
        event.loader = async () => {
            // Start curtain slide-up via CSS transition
            curtain.style.transition = 'transform 0.55s cubic-bezier(0.77,0,0.175,1)';
            text.style.transition = 'opacity 0.4s ease-out 0.2s, transform 0.4s ease-out 0.2s';

            // Force reflow so transition starts from current position
            curtain.offsetHeight;

            curtain.style.transform = 'translateY(0%)';
            text.style.opacity = '1';
            text.style.transform = 'translateY(0)';

            // Wait for both: curtain animation (550ms) AND page fetch
            await Promise.all([
                new Promise(r => setTimeout(r, 560)),
                originalLoader()
            ]);
        };
    });

    // --- 2. REVEAL (after swap: curtain slides away) ---
    document.addEventListener('astro:after-swap', () => {
        if (!curtain || !text) return;

        // Ensure curtain covers (instant reset for new page)
        curtain.style.transition = 'none';
        text.style.transition = 'none';
        curtain.style.transform = 'translateY(0%)';
        text.style.opacity = '1';
        text.style.transform = 'translateY(0)';

        // Force reflow
        curtain.offsetHeight;

        // Slide curtain up and fade text
        curtain.style.transition = 'transform 0.55s cubic-bezier(0.77,0,0.175,1)';
        text.style.transition = 'opacity 0.35s ease-in, transform 0.35s ease-in';

        curtain.style.transform = 'translateY(-100%)';
        text.style.opacity = '0';
        text.style.transform = 'translateY(-2rem)';

        // Reset after animation completes
        setTimeout(() => {
            curtain.style.transition = 'none';
            text.style.transition = 'none';
            curtain.style.transform = 'translateY(100%)';
            text.style.opacity = '0';
            text.style.transform = 'translateY(2rem)';
        }, 600);
    });
</script>