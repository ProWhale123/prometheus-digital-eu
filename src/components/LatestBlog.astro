---
// src/components/LatestBlog.astro
// Shows the 3 latest blog posts on the homepage — drives internal linking + content freshness signals

import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import FloatingElement from "./FloatingElement.astro";

const allPosts = await getCollection("blog");
const latestPosts = allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
---

<section class="py-24 md:py-32 relative overflow-hidden">
    <FloatingElement speed={-0.15} class="top-20 -right-20 z-0 opacity-10">
        <div class="w-80 h-80 rounded-full bg-sky-500 blur-[100px]"></div>
    </FloatingElement>

    <div
        class="absolute inset-0 bg-[url('/images/grid-pattern.svg')] bg-[length:50px_50px] opacity-[0.03] pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
            <span
                class="inline-block px-4 py-1.5 rounded-full bg-sky-500/10 text-sky-300 text-sm font-bold border border-sky-500/20 uppercase tracking-wider mb-6 animate-in"
            >
                Blog
            </span>
            <h2
                class="text-3xl md:text-5xl font-bold text-white mb-4 animate-in"
            >
                Latest <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300"
                    >Articles</span
                >
            </h2>
            <p class="text-lg text-gray-400 max-w-2xl mx-auto animate-in">
                Practical guides, tips, and strategies to help your
                business succeed in the digital space.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {
                latestPosts.map((post, index) => (
                    <article
                        class="group animate-in"
                        style={`animation-delay: ${index * 100}ms`}
                    >
                        <a
                            href={`/blog/${post.slug}/`}
                            class="block h-full bg-gray-900/80 backdrop-blur-sm border border-white/10 rounded-2xl overflow-hidden hover:border-sky-500/40 transition-all duration-500 hover:shadow-[0_0_30px_rgba(56,189,248,0.08)] hover:-translate-y-1"
                        >
                            <div class="h-48 overflow-hidden relative">
                                <div class="absolute inset-0 bg-sky-900/0 group-hover:bg-sky-900/20 transition-colors duration-500 z-10" />
                                <Image
                                    src={post.data.heroImage}
                                    alt={post.data.title}
                                    width={600}
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                />
                            </div>

                            <div class="p-6">
                                <div class="flex flex-wrap gap-2 mb-3">
                                    {post.data.tags
                                        .slice(0, 2)
                                        .map((tag: string) => (
                                            <span class="text-[10px] font-bold uppercase tracking-widest text-sky-400 border border-sky-500/20 px-2 py-0.5 rounded bg-sky-500/5">
                                                {tag}
                                            </span>
                                        ))}
                                </div>

                                <h3 class="text-lg font-bold text-white mb-2 leading-snug group-hover:text-sky-300 transition-colors line-clamp-2">
                                    {post.data.title}
                                </h3>

                                <p class="text-sm text-gray-400 mb-4 line-clamp-2 leading-relaxed">
                                    {post.data.description}
                                </p>

                                <div class="flex items-center justify-between">
                                    <time
                                        datetime={
                                            post.data.pubDate
                                                .toISOString()
                                                .split("T")[0]
                                        }
                                        class="text-xs text-gray-500"
                                    >
                                        {post.data.pubDate.toLocaleDateString(
                                            "en-US",
                                            {
                                                year: "numeric",
                                                month: "short",
                                                day: "numeric",
                                            },
                                        )}
                                    </time>

                                    <span class="flex items-center text-sky-400 font-semibold text-xs uppercase tracking-wider">
                                        <span class="mr-1.5 group-hover:mr-3 transition-all">
                                            Read More
                                        </span>
                                        <svg
                                            class="w-3.5 h-3.5"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M17 8l4 4m0 0l-4 4m4-4H3"
                                            />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </a>
                    </article>
                ))
            }
        </div>

        <div class="text-center mt-12">
            <a
                href="/blog"
                class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full border border-sky-500/30 text-sky-400 font-bold uppercase tracking-wider text-sm hover:bg-sky-500/10 hover:border-sky-500/50 transition-all duration-300"
            >
                View All Articles
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </div>
</section>
