---
// src/components/Hero.astro
import SpotlightHeroBackground from "./react/SpotlightHeroBackground.jsx";
import MagneticButton from "./react/MagneticButton.jsx";
import { Image } from "astro:assets";
import heroMockImage from "../assets/images/project-21.jpg";

const stats = [
    // The first stat counts up (see the script block).
    { value: "100/100", label: "Google PageSpeed", countUp: true },
    { value: "40+", label: "Projects delivered" },
    { value: "GEO / AI-ready", label: "Future-proof SEO" },
];
---

<section
    id="home"
    class="relative min-h-[100svh] flex items-center justify-center overflow-hidden bg-[#0B1120]"
>
    <SpotlightHeroBackground client:visible />

    <!-- Ambient glows (static, GPU-cheap) -->
    <div
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-sky-500/10 rounded-full blur-[80px] md:blur-[120px] pointer-events-none z-0 mix-blend-screen"
    >
    </div>
    <div
        class="absolute top-[18%] right-[8%] w-48 h-48 md:w-72 md:h-72 bg-cyan-500/10 rounded-full blur-[80px] md:blur-[110px] pointer-events-none z-0 hidden sm:block"
    >
    </div>

    <div
        class="relative z-10 container mx-auto px-4 md:px-6 w-full pt-32 md:pt-36 pb-20 lg:grid lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-12 lg:text-left"
    >
        <!-- LEFT COLUMN: text block (single-column centered stack below lg) -->
        <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
        <!-- Availability / status pill -->
        <div
            class="hero-pill inline-flex items-center gap-2.5 mb-8 px-4 py-2 rounded-full border border-sky-500/20 bg-sky-500/5 text-xs md:text-sm text-sky-300 font-medium"
        >
            <span class="relative flex h-2 w-2">
                <span
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"
                ></span>
                <span
                    class="relative inline-flex rounded-full h-2 w-2 bg-sky-500"
                ></span>
            </span>
            Accepting new projects for 2026
        </div>

        <h1
            class="relative font-black text-white uppercase tracking-tighter mb-8 md:mb-10 group cursor-default w-full"
        >
            <div class="overflow-hidden py-2">
                <span
                    class="hero-title-element block text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-gray-300 leading-[1.1]"
                >
                    WE BUILD YOUR BUSINESS'S
                </span>
            </div>

            <div class="overflow-hidden py-4">
                <span
                    class="hero-title-element block text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl text-transparent bg-clip-text bg-gradient-to-b from-white via-sky-100 to-sky-300 filter drop-shadow-2xl leading-[1.1] md:leading-tight"
                >
                    DIGITAL FUTURE
                </span>
            </div>
        </h1>

        <p
            class="hero-desc max-w-2xl mx-auto lg:mx-0 text-base sm:text-lg md:text-xl text-gray-400 font-light leading-relaxed mb-9 md:mb-10 px-4 lg:px-0"
        >
            Strategic, <span class="text-white font-medium">code-based</span>
            websites that are not just beautiful, but <span
                class="text-white font-medium">convert</span
            >. Faster and more secure than template builders — for better Google
            rankings and more customers.
        </p>

        <!-- Dual CTA -->
        <div
            class="hero-btn w-full flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-center px-4 lg:px-0 mb-14"
        >
            <MagneticButton
                href="/contact/"
                client:visible
                className="group relative inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 bg-white text-[#0B1120] font-bold rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(14,165,233,0.3)]"
            >
                <span
                    class="absolute inset-0 w-full h-full bg-gradient-to-r from-sky-400 via-cyan-300 to-sky-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                ></span>
                <span
                    class="relative z-10 flex items-center justify-center gap-3 tracking-wide text-sm md:text-base"
                >
                    FREE CONSULTATION
                    <svg
                        class="w-4 h-4 md:w-5 md:h-5 transition-transform duration-300 group-hover:translate-x-1"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                    >
                </span>
            </MagneticButton>

            <a
                href="/works/"
                class="group inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 border border-white/15 text-white font-bold rounded-full text-sm md:text-base hover:bg-white/5 hover:border-white/30 transition-all duration-300"
            >
                View our work
                <svg
                    class="w-4 h-4 md:w-5 md:h-5 ml-2 text-sky-400 transition-transform duration-300 group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"></path></svg
                >
            </a>
        </div>

        <!-- Trust / stat strip -->
        <div
            class="hero-stats flex flex-wrap items-center justify-center lg:justify-start gap-x-8 gap-y-4 md:gap-x-12"
        >
            {
                stats.map((s, i) => (
                    <>
                        {i > 0 && (
                            <div class="hidden sm:block w-px h-10 bg-white/10" />
                        )}
                        <div class="text-center lg:text-left">
                            <div class="text-lg md:text-2xl font-black text-white tracking-tight">
                                {s.countUp ? (
                                    /* Count-up: tabular-nums + fixed min-width → no layout shift. */
                                    <span
                                        class="hero-count inline-block tabular-nums text-left min-w-[3.6ch]"
                                        data-count-target="100"
                                        data-count-suffix="/100"
                                    >
                                        0/100
                                    </span>
                                ) : (
                                    s.value
                                )}
                            </div>
                            <div class="text-[10px] md:text-xs text-gray-500 uppercase tracking-widest mt-1">
                                {s.label}
                            </div>
                        </div>
                    </>
                ))
            }
        </div>
        </div>
        <!-- /LEFT COLUMN -->

        <!-- RIGHT COLUMN: browser-frame product mock (lg+ only; hidden below lg to keep the centered stack) -->
        <div class="hero-visual hidden lg:block w-full">
            <div
                class="relative rounded-2xl border border-white/10 bg-[#0d1424] shadow-[0_30px_80px_-20px_rgba(0,0,0,0.6)] overflow-hidden"
            >
                <!-- Browser chrome -->
                <div
                    class="flex items-center gap-3 px-4 py-3 border-b border-white/10 bg-white/[0.02]"
                >
                    <div class="flex items-center gap-1.5">
                        <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
                        <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
                        <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
                    </div>
                    <div
                        class="flex-1 flex items-center justify-center gap-2 px-3 py-1.5 rounded-full bg-white/5 text-[11px] text-gray-400 font-mono tracking-tight"
                    >
                        <svg
                            class="w-3 h-3 text-sky-400/70"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                            ></path></svg
                        >
                        prometheusdigital.eu
                    </div>
                </div>

                <!-- Real project screenshot (LCP candidate: eager + high priority, fixed ratio → no CLS) -->
                <div class="relative aspect-[16/10] w-full">
                    <Image
                        src={heroMockImage}
                        alt="A custom-built website by Prometheus Digital"
                        class="w-full h-full object-cover object-top"
                        widths={[640, 960, 1280, 1600]}
                        sizes="(min-width: 1024px) 48vw, 0px"
                        quality="high"
                        loading="eager"
                        fetchpriority="high"
                        width={1600}
                        height={1000}
                    />
                    <!-- Sky-accent performance badge (solid bg, no backdrop → cheap) -->
                    <div
                        class="absolute bottom-3 right-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-sky-500 text-white text-[11px] font-bold tracking-tight shadow-lg"
                    >
                        <svg
                            class="w-3.5 h-3.5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"
                            ></path></svg
                        >
                        100/100 PageSpeed
                    </div>
                </div>
            </div>
        </div>
        <!-- /RIGHT COLUMN -->
    </div>

    <div
        class="hero-scroll absolute bottom-6 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 pointer-events-none"
    >
        <span
            class="text-[10px] md:text-xs font-mono text-gray-500 uppercase tracking-widest"
            >Scroll</span
        >
        <div
            class="w-[1px] h-8 md:h-12 bg-gradient-to-b from-sky-500 to-transparent"
        >
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    function animateHero() {
        if (!document.querySelector(".hero-title-element")) return;
        // Reduced-motion: leave content at its visible CSS default — no reveal.
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        try {
        gsap.set(".hero-pill", { y: 20, opacity: 0 });
        gsap.set(".hero-title-element", { y: 50, opacity: 0, filter: "blur(10px)", scale: 1.05 });
        gsap.set(".hero-desc", { y: 30, opacity: 0, filter: "blur(4px)" });
        gsap.set(".hero-btn", { y: 30, opacity: 0, scale: 0.95 });
        gsap.set(".hero-stats", { y: 20, opacity: 0 });
        gsap.set(".hero-visual", { x: 40, opacity: 0, filter: "blur(6px)" });
        gsap.set(".hero-scroll", { opacity: 0 });

        const tl = gsap.timeline({ delay: 0.05 });

        tl.to(".hero-pill", {
            y: 0, opacity: 1, duration: 0.5, ease: "power2.out",
        })
            .to(".hero-title-element", {
                y: 0, opacity: 1, filter: "blur(0px)", scale: 1, duration: 0.6, stagger: 0.1, ease: "power3.out",
            }, "-=0.25")
            .to(".hero-desc", {
                y: 0, opacity: 1, filter: "blur(0px)", duration: 0.5, ease: "power2.out",
            }, "-=0.4")
            .to(".hero-btn", {
                y: 0, opacity: 1, scale: 1, duration: 0.4, ease: "back.out(1.5)",
            }, "-=0.3")
            .to(".hero-stats", {
                y: 0, opacity: 1, duration: 0.5, ease: "power2.out",
            }, "-=0.2")
            .to(".hero-visual", {
                x: 0, opacity: 1, filter: "blur(0px)", duration: 0.7, ease: "power3.out",
            }, "-=0.45")
            .to(".hero-scroll", { opacity: 1, duration: 0.5 }, "-=0.3");
        } catch (e) {
            // GSAP failure — keep hero content visible (LCP/SEO safeguard)
            document.querySelectorAll(".hero-pill, .hero-title-element, .hero-desc, .hero-btn, .hero-stats, .hero-visual, .hero-scroll").forEach((el) => { el.style.opacity = "1"; el.style.transform = "none"; el.style.filter = "none"; });
        }
    }

    // COUNT-UP: animates the "100/100" stat. Writes only textContent, starts via
    // IntersectionObserver, tabular-nums + fixed min-width keep it layout-shift free.
    function animateHeroCount() {
        const el = document.querySelector<HTMLElement>(".hero-count");
        if (!el) return;

        const target = parseInt(el.dataset.countTarget || "100", 10);
        const suffix = el.dataset.countSuffix || "";
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (reduce) {
            el.textContent = target + suffix;
            return;
        }

        let started = false;
        const run = () => {
            if (started) return;
            started = true;
            const duration = 1100; // ms
            const start = performance.now();
            const tick = (now: number) => {
                const t = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
                el.textContent = Math.round(eased * target) + suffix;
                if (t < 1) requestAnimationFrame(tick);
                else el.textContent = target + suffix;
            };
            requestAnimationFrame(tick);
        };

        if (!("IntersectionObserver" in window)) {
            run();
            return;
        }
        const io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    run();
                    io.disconnect();
                }
            });
        }, { threshold: 0.6 });
        io.observe(el);
    }

    document.addEventListener("astro:page-load", () => {
        animateHero();
        animateHeroCount();
    });
</script>
