---
interface Props {
    speed?: number; // 1 = nagyon gyors, 0.2 = lassú, -0.5 = felfelé úszik
    class?: string;
}

const { speed = 0.2, class: className = "" } = Astro.props;
---

<div 
    class={`floating-element absolute pointer-events-none will-change-transform ${className}`}
    data-speed={speed}
>
    <slot />
</div>

<script>
    function initFloating() {
        const elements = document.querySelectorAll('.floating-element');
        if (elements.length === 0) return;

        if (window.matchMedia('(pointer: coarse)').matches) return;

        const docHeight = () => document.documentElement.scrollHeight - window.innerHeight;

        function onScroll() {
            const progress = window.scrollY / (docHeight() || 1);
            elements.forEach((el) => {
                const speed = parseFloat(el.getAttribute('data-speed') || '0.2');
                const y = 500 * speed * progress;
                (el as HTMLElement).style.transform = `translateY(${y}px)`;
            });
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    }

    initFloating();
    document.addEventListener('astro:page-load', initFloating);
</script>