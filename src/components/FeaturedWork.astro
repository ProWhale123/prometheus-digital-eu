---
// src/components/FeaturedWork.astro (ENGLISH VERSION)
import { Image } from 'astro:assets';
import TiltCardAstro from './TiltCardAstro.astro';
import ParallaxImage from './ParallaxImage.astro';

import project1Image from '../assets/images/project-1.jpg';
import project2Image from '../assets/images/project-2.jpg';
import project3Image from '../assets/images/project-3.jpg';
import project7Image from '../assets/images/project-7.png';
import project8Image from '../assets/images/project-8.png';
import project9Image from '../assets/images/project-9.jpg';
import project10Image from '../assets/images/project-10.jpg';
import project12Image from '../assets/images/project-12.jpg';
import project13Image from '../assets/images/project-13.jpg';

const projects = [
    {
        title: "MSM Chicken Goods",
        description: "Full website for a premium food manufacturer. Modern animations and product showcase.",
        tags: ["Food Industry", "B2B", "Astro"],
        imageSrc: project12Image,
        liveUrl: "https://msmchickengoods.com/"
    },
    {
        title: "Nebula Motors",
        description: "Immersive, cyberpunk aesthetic website with stunning motion design.",
        tags: ["Automotive", "Motion UI", "Immersive"],
        imageSrc: project8Image,
        liveUrl: "https://nebula-motors.eu/"
    },
    {
        title: "Artisan Coffee Shop",
        description: "Elegant, dark-toned showcase site for a premium cafe.",
        tags: ["Hospitality", "Premium", "Dark Mode"],
        imageSrc: project9Image,
        liveUrl: "https://coffee-shop-demo-six.vercel.app/"
    },
    {
        title: "LUX SECURE",
        description: "Futuristic cybersecurity website with live interceptor grid visualization.",
        tags: ["Cybersecurity", "Dark Mode", "Animated"],
        imageSrc: project7Image,
        liveUrl: "https://luxsecure.eu/"
    },
    {
        title: "DOL Bt. — Travel Agency",
        description: "Professional website for a travel agency specializing in the 'Hatartalanul!' program.",
        tags: ["Client Project", "Tourism", "Lead Gen"],
        imageSrc: project1Image,
        liveUrl: "https://dolbt.eu/"
    },
    {
        title: "Artisan Ice Cream Parlor",
        description: "Cheerful, warm-colored website for an artisan ice cream shop.",
        tags: ["Hospitality", "Light Theme", "Branding"],
        imageSrc: project10Image,
        liveUrl: "https://ice-cream-shop-eta.vercel.app/"
    },
    {
        title: "Golden Wheat Bakery",
        description: "Narrative-design bakery website with three generations of tradition.",
        tags: ["Bakery", "Storytelling", "Clean"],
        imageSrc: project13Image,
        liveUrl: "https://pekseg-demo.vercel.app/"
    },
    {
        title: "Gastronomo Fine Dining",
        description: "Exclusive fine dining website with interactive cursor effects and reservation system.",
        tags: ["Fine Dining", "UI/UX", "Animated"],
        imageSrc: project2Image,
        liveUrl: "https://gastronomo.eu/"
    },
];
---
<section id="works" class="py-24 md:py-32 overflow-hidden relative">
    <div class="absolute inset-0 bg-[url('/images/grid-pattern.svg')] bg-[length:60px_60px] opacity-[0.02] pointer-events-none"></div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col items-center mb-16 animate-on-scroll">
            <div class="text-center max-w-2xl">
                <h2 class="text-3xl md:text-5xl font-black text-white mb-6 uppercase tracking-tight">
                    Our Featured <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300">Work</span>
                </h2>
                <p class="text-lg text-gray-400 font-light">
                    Every pixel has a purpose. See how we helped our partners stand out in the digital space.
                </p>
            </div>
        </div>

        <div class="relative max-w-7xl mx-auto animate-on-scroll">
            <div id="featured-work-gallery" class="flex overflow-x-auto snap-x snap-mandatory pb-12 scroll-smooth no-scrollbar">
                {projects.map(project => (
                    <div class="flex-shrink-0 w-[85vw] md:w-[45vw] lg:w-[30vw] snap-center px-4">
                        <TiltCardAstro class="h-full">
                            <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="group block h-full bg-gray-900 border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-sky-500/50 hover:shadow-2xl">
                                <div class="relative overflow-hidden aspect-video">
                                    <div class="absolute inset-0 bg-sky-900/20 group-hover:bg-transparent transition-colors z-10"></div>
                                    <ParallaxImage
                                        src={project.imageSrc}
                                        alt={project.title}
                                        height="h-full"
                                    />
                                </div>
                                <div class="p-6 md:p-8">
                                    <h3 class="text-xl font-bold text-white mb-3 group-hover:text-sky-400 transition-colors">{project.title}</h3>
                                    <p class="text-gray-400 text-sm mb-6 leading-relaxed line-clamp-3">{project.description}</p>
                                    <div class="flex flex-wrap gap-2">
                                        {project.tags.map(tag => (
                                            <span class={`text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider ${tag === 'Client Project' ? 'bg-emerald-500/10 text-emerald-300 border border-emerald-500/20' : 'bg-sky-500/10 text-sky-300'}`}>{tag}</span>
                                        ))}
                                    </div>
                                </div>
                            </a>
                        </TiltCardAstro>
                    </div>
                ))}
            </div>

            <div class="hidden md:flex justify-end absolute -top-24 right-0 gap-4">
                <button id="scroll-left-btn" aria-label="Scroll left" class="w-12 h-12 rounded-full border border-white/10 text-white flex items-center justify-center transition-all duration-300 hover:bg-white hover:text-black hover:scale-110 active:scale-90">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button id="scroll-right-btn" aria-label="Scroll right" class="w-12 h-12 rounded-full border border-white/10 text-white flex items-center justify-center transition-all duration-300 hover:bg-white hover:text-black hover:scale-110 active:scale-90">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </button>
            </div>
        </div>
    </div>
</section>

<style>
.no-scrollbar::-webkit-scrollbar {
    display: none;
}
.no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
}
</style>

<script>
    function initGallery() {
        const gallery = document.getElementById('featured-work-gallery');
        const scrollLeftBtn = document.getElementById('scroll-left-btn');
        const scrollRightBtn = document.getElementById('scroll-right-btn');

        if (gallery && scrollLeftBtn && scrollRightBtn) {
            const getScrollAmount = () => {
                const card = gallery.querySelector('div:first-child');
                return card ? card.offsetWidth : 300;
            };

            scrollLeftBtn.onclick = () => {
                gallery.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
            };

            scrollRightBtn.onclick = () => {
                gallery.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
            };
        }
    }

    initGallery();
    document.addEventListener('astro:page-load', initGallery);
</script>
