---
// src/components/ServiceSchema.astro
// JSON-LD Service schema for service landing pages — enables rich results in Google

interface ServiceItem {
    name: string;
    description: string;
    url?: string;
    /** Net price in EUR; if set, included in the Offer schema. */
    price?: number;
}

interface Props {
    services: ServiceItem[];
    priceRange?: string;
}

const { services, priceRange = "€749 - €6,000" } = Astro.props;

const siteUrl = "https://www.prometheusdigital.eu";

const schema = services.map((service) => ({
    "@context": "https://schema.org",
    "@type": "Service",
    name: service.name,
    description: service.description,
    url: service.url ? `${siteUrl}${service.url}` : siteUrl,
    provider: {
        "@type": "Organization",
        name: "Prometheus Digital",
        url: siteUrl,
        logo: `${siteUrl}/logo.jpg`,
    },
    areaServed: {
        "@type": "Place",
        name: "Europe",
    },
    serviceType: service.name,
    offers: {
        "@type": "Offer",
        priceCurrency: "EUR",
        ...(service.price ? { price: String(service.price) } : {}),
        priceSpecification: {
            "@type": "PriceSpecification",
            priceCurrency: "EUR",
            valueAddedTaxIncluded: false,
            ...(service.price ? { price: String(service.price) } : {}),
        },
    },
}));
---

{
    schema.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))
}
