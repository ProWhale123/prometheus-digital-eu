---
// src/components/MagneticButtonAstro.astro
// Vanilla JS replacement for React MagneticButton
// Uses GSAP (already loaded) for elastic spring-back animation
interface Props {
  class?: string;
}
const className = Astro.props.class || "";
---

<div class={`magnetic-btn relative inline-block ${className}`}>
  <span class="magnetic-btn-inner relative block z-10">
    <slot />
  </span>
</div>

<script>
  function initMagneticButtons() {
    if (window.matchMedia('(pointer: coarse)').matches) return;

    document.querySelectorAll('.magnetic-btn').forEach((btn) => {
      if (btn.hasAttribute('data-magnetic-init')) return;
      btn.setAttribute('data-magnetic-init', '');

      const el = btn as HTMLElement;
      const inner = btn.querySelector('.magnetic-btn-inner') as HTMLElement;

      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - (rect.left + rect.width / 2);
        const y = e.clientY - (rect.top + rect.height / 2);

        el.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
        if (inner) inner.style.transform = `translate(${x * 0.1}px, ${y * 0.1}px)`;
      });

      btn.addEventListener('mouseleave', () => {
        el.style.transition = 'transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1)';
        el.style.transform = 'translate(0, 0)';
        if (inner) {
          inner.style.transition = 'transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1)';
          inner.style.transform = 'translate(0, 0)';
        }
        const cleanup = () => {
          el.style.transition = '';
          if (inner) inner.style.transition = '';
        };
        el.addEventListener('transitionend', cleanup, { once: true });
      });
    });
  }

  initMagneticButtons();
  document.addEventListener('astro:page-load', initMagneticButtons);
</script>
