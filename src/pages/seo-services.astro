---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Contact from "../components/Contact.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ServiceSchema from "../components/ServiceSchema.astro";
import MagneticButtonAstro from "../components/MagneticButtonAstro.astro";
import SpotlightCard from "../components/SpotlightCard.astro";

import {
    fmtEur,
    webModules,
    seoOneTime,
    seoMonthlyTiers,
    seoAddons,
    geoServices,
    SEO_MIN_MONTHS,
    COMPLEX_EXTRA_SUBPAGE,
} from "../data/pricing";

const seoProcess = [
    {
        step: "01",
        title: "SEO Audit & Assessment",
        description:
            "We start with a comprehensive technical audit: speed, indexing, structure, competitor analysis. We map out where your website stands now and where the market gaps are.",
    },
    {
        step: "02",
        title: "Keyword Research & Gap Analysis",
        description:
            "We identify the high-value searches your customers are making. We analyse competitors' keyword strategies and find the areas where they are weak.",
    },
    {
        step: "03",
        title: "Technical SEO & Code Optimization",
        description:
            "We build the results into the backend code too: JSON-LD structured data, schema markup, meta data optimisation, Core Web Vitals fine-tuning.",
    },
    {
        step: "04",
        title: "Content & Link Building",
        description:
            "Monthly expert articles with pillar content — at the pace of your chosen plan. The higher tiers add link building: quality links and PR placements to grow domain authority (DA).",
    },
    {
        step: "05",
        title: "Measurement & Monthly Report",
        description:
            "A transparent PDF report at the end of every month: rankings, traffic, conversions. We continuously refine the strategy based on the data.",
    },
];

// SEO Foundation = Technical SEO Sprint + Keyword & Content Strategy
const technicalSprintIncludes = [
    {
        title: "SEO Audit & Assessment",
        description:
            "Full technical audit: speed, indexing, site structure, competitor analysis.",
    },
    {
        title: "Core Web Vitals & Technical Fix",
        description:
            "Speed optimisation, image optimisation, sitemap and robots.txt, component-level metadata.",
    },
    {
        title: "JSON-LD Structured Data",
        description:
            "Custom schema.org code that explicitly defines the business, services and service area for Google.",
    },
    {
        title: "Internal Link Structure & Meta Data",
        description:
            "Custom meta title and description, contextual internal links, breadcrumb implementation.",
    },
    {
        title: "GA4 + GSC Setup & Configuration",
        description:
            "Google Analytics 4 and Search Console setup (or cleanup of existing accounts), ownership verification, sitemap submission and micro-conversion measurement (form, phone, email clicks).",
    },
];

const keywordContentIncludes = [
    {
        title: "B2B/B2C Keyword Research",
        description:
            "Detailed analysis of high-value searches and competitors' strategies.",
    },
    {
        title: "Search-Intent Map",
        description:
            "Keyword clusters mapped to every stage of the buyer journey, so the right content serves the right intent.",
    },
    {
        title: "Competitor Gap Analysis",
        description:
            "Identifying the market gaps where we can get ahead of the competition.",
    },
    {
        title: "Content Calendar & Pillar Structure",
        description:
            "A scheduled plan of thematic pillar content and supporting articles — preparation for ongoing content production.",
    },
];

const complexSetupIncludes = [
    {
        title: "Full SEO Foundation",
        description:
            "The complete Technical SEO Sprint and Keyword & Content Strategy — technical groundwork plus keyword and content strategy.",
    },
    {
        title: "Full Technical SEO Implementation",
        description:
            "Core Web Vitals optimisation (within the limits of the existing platform), WebP image conversion, sitemap regeneration, robots.txt cleanup, redirects.",
    },
    {
        title: "Schema.org Markup Implementation",
        description:
            "Organization, BreadcrumbList, Service/Product, FAQ and Article schemas in JSON-LD format on every relevant page.",
    },
    {
        title: "Content Audit & Up to 5 Page Expansion",
        description: `Critical sub-pages rewritten or expanded, keyword-optimised. Plus 2 new foundational blog posts. Each additional sub-page: ${fmtEur(COMPLEX_EXTRA_SUBPAGE)} / page.`,
    },
    {
        title: "GEO/AI Audit + Setup",
        description:
            "Full visibility audit and technical setup for AI search engines (ChatGPT, Gemini, Perplexity, Google AI Overview) — entity linking and an AI-friendly content structure.",
    },
    {
        title: "GA4 + GSC + Local SEO",
        description:
            "Analytics and Search Console setup, conversion funnel tracking, Google Business Profile cleanup and local schema markup.",
    },
];

const faqs = [
    {
        question: "How long until I see results?",
        answer: "Google's algorithm typically takes 3-6 months to start pricing in content development and authority building. In the first month the basic technical fixes are already measurable, but a stable improvement in search positions typically begins from month 3.",
    },
    {
        question: "Do you guarantee first place on Google?",
        answer: "No one can responsibly guarantee that — anyone who does is misleading you. What we do guarantee: measurable, continuous improvement in search positions, data-driven decisions, and transparent reports where you can see exactly how things progress.",
    },
    {
        question: "Do I need a new website for SEO?",
        answer: "Not necessarily. Our SEO service can be applied to existing websites too. However, if your site runs on outdated technology (e.g. an old WordPress template), technical limitations may hinder the results. In that case we'll discuss the options during a consultation.",
    },
    {
        question: "Which monthly SEO plan should I choose?",
        answer: `SEO Local (${fmtEur(seoMonthlyTiers[0].price)}/mo) is ideal for local or single-region businesses. SEO Growth (${fmtEur(seoMonthlyTiers[1].price)}/mo) is the most popular: for national providers and small webshops, with link building and local SEO. SEO Dominance (${fmtEur(seoMonthlyTiers[2].price)}/mo) is for competitive markets — maximum cadence, premium link building and full local coverage. In a free assessment we'll help you pick the level that fits your goals.`,
    },
    {
        question: "What's the difference between SEO Foundation and Complex SEO Setup?",
        answer: `SEO Foundation (${fmtEur(seoOneTime.foundation.price)}) is the recommended groundwork for everyone — for our own clients and existing sites where the technical basics are solid. It includes the Technical SEO Sprint (${fmtEur(seoOneTime.technicalSprint.price)}) and the Keyword & Content Strategy (${fmtEur(seoOneTime.keywordContent.price)}) at a bundle discount. Complex SEO Setup (${fmtEur(seoOneTime.complex.price)}) is needed when page expansion is required (up to 5, additional sub-pages ${fmtEur(COMPLEX_EXTRA_SUBPAGE)} each) or you also want AI search visibility — it includes the full GEO/AI Audit + Setup.`,
    },
    {
        question: "Can I order the Technical SEO Sprint or the Keyword & Content Strategy separately?",
        answer: `Yes. The Technical SEO Sprint on its own is ${fmtEur(seoOneTime.technicalSprint.price)}, and the Keyword & Content Strategy is ${fmtEur(seoOneTime.keywordContent.price)}. The two together, as SEO Foundation, are ${fmtEur(seoOneTime.foundation.price)} — cheaper as a bundle than buying them individually.`,
    },
    {
        question: "What is GEO/AEO and do I need it?",
        answer: "GEO (Generative Engine Optimization) and AEO (Answer Engine Optimization) ensure your business appears as a source in AI-powered search too — ChatGPT, Gemini, Perplexity, Google AI Overview. A growing share of searches end without a click, in an AI answer; anyone left out of those becomes invisible. It can be ordered as a standalone product (Audit, Setup, Monitoring) and as an add-on alongside monthly SEO.",
    },
    {
        question: "What is the minimum commitment for the monthly plans?",
        answer: `A minimum of ${SEO_MIN_MONTHS} months, because SEO results typically take 3-6 months to materialise. Every monthly SEO client first goes through a SEO Foundation or Technical SEO Sprint setup — there is no "bare" monthly fee without a proper foundation.`,
    },
    {
        question: "What if some elements already work well on my website?",
        answer: "We price flexibly, of course. If, for example, you already have a working GA4 + Search Console setup, or your schema markup is partially in place, we don't add those to the price. In a free consultation we tailor the setup to your current situation — you only pay for what is genuinely work.",
    },
    {
        question: "How do you measure results?",
        answer: "At the end of every month we send a transparent PDF report: search position changes, organic traffic trends, conversions (phone calls, forms, contact requests), and the next month's strategy. Plus, depending on the plan, a monthly or bi-weekly online consultation.",
    },
];
---

<Layout
    title="SEO Services for Businesses | Prometheus Digital"
    description="Professional SEO for businesses: SEO Foundation from €870, three-tier monthly SEO (€450–€1,350) and GEO/AI visibility in AI search engines."
>
    <Header />

    <ServiceSchema
        services={[
            {
                name: "SEO Foundation",
                description:
                    "One-time SEO groundwork: Technical SEO Sprint (audit, Core Web Vitals, schema/JSON-LD, sitemap, GSC/GA4) and Keyword & Content Strategy in one package.",
                url: "/seo-services#packages",
                price: seoOneTime.foundation.price,
            },
            {
                name: "Complex SEO Setup",
                description:
                    "Full SEO transformation of an existing website not built by us: SEO Foundation + 5 sub-page content expansion + full GEO/AI Audit and Setup.",
                url: "/seo-services#packages",
                price: seoOneTime.complex.price,
            },
            {
                name: "SEO Local - Monthly SEO Plan",
                description:
                    "Monthly search engine optimization for local / single-region businesses: 2 expert articles, monthly on-page work, technical monitoring and a monthly report.",
                url: "/seo-services#packages",
                price: seoMonthlyTiers[0].price,
            },
            {
                name: "SEO Growth - Monthly SEO Plan",
                description:
                    "Active growth plan: 4 expert articles, link building, baseline local SEO management, quarterly competitor analysis and a monthly strategy call.",
                url: "/seo-services#packages",
                price: seoMonthlyTiers[1].price,
            },
            {
                name: "SEO Dominance - Monthly SEO Plan",
                description:
                    "Premium monthly search engine optimization: 6 expert articles, premium link building (6-8 links + 2 PR articles), full local SEO and monthly competitor analysis.",
                url: "/seo-services#packages",
                price: seoMonthlyTiers[2].price,
            },
            {
                name: "GEO/AI Setup",
                description:
                    "Technical and content foundation for visibility in AI search engines (ChatGPT, Gemini, Perplexity, Google AI Overview): semantic optimisation, entity linking, AI-friendly content structure.",
                url: "/seo-services#geo",
                price: geoServices[1].price,
            },
        ]}
    />

    <main id="main-content" class="overflow-hidden">
        <!-- HERO -->
        <section
            class="relative pt-48 pb-24 md:pt-56 md:pb-32 flex items-center justify-center text-center overflow-hidden"
        >
            <div class="absolute inset-0 bg-gray-950"></div>
            <div
                class="absolute inset-0 bg-gradient-to-b from-emerald-950/20 via-transparent to-transparent"
            >
            </div>
            <!-- Static ambient glow — reduced blur on mobile to avoid GPU overload -->
            <div class="absolute top-20 -right-40 z-0 opacity-10 pointer-events-none">
                <div class="w-[500px] h-[500px] rounded-full bg-emerald-600 blur-[60px] md:blur-[150px]"></div>
            </div>

            <div class="container mx-auto px-6 text-center relative z-10">
                <Breadcrumb
                    items={[
                        {
                            name: "SEO Services",
                            url: "/seo-services",
                        },
                    ]}
                />

                <div
                    class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-sm text-emerald-400"
                >
                    <span
                        class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"
                    ></span>
                    Proactive Growth
                </div>

                <h1
                    class="text-4xl md:text-6xl lg:text-7xl font-black text-white mb-6 tracking-tight"
                >
                    Don't wait for customers.<br />
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-300"
                    >
                        Get them from Google.
                    </span>
                </h1>

                <p
                    class="max-w-3xl mx-auto text-lg md:text-xl text-gray-300 mb-10"
                >
                    Even the best product stays invisible if your customers
                    can't find it. We help your business be the first one Google
                    — and the AI search engines — recommend when a potential
                    client searches.
                </p>

                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <MagneticButtonAstro>
                        <a
                            href="/contact?topic=seo-assessment"
                            class="inline-flex items-center justify-center px-10 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white font-bold rounded-full text-lg hover:shadow-[0_0_30px_rgba(16,185,129,0.4)] hover:scale-105 transition-all duration-300"
                        >
                            Free SEO Assessment
                        </a>
                    </MagneticButtonAstro>
                    <a
                        href="#packages"
                        class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-bold rounded-full text-lg hover:bg-white/5 transition-all duration-300"
                    >
                        SEO Packages ↓
                    </a>
                </div>
            </div>
        </section>

        <!-- WHY SEO -->
        <section class="py-20 bg-[#0B1120] border-b border-white/5">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                        Why is SEO the best investment?
                    </h2>
                    <p class="text-lg text-gray-400">
                        Google Ads bring nothing once you turn them off. SEO, on
                        the other hand, is a continuously working, 24/7 customer
                        acquisition machine — that gets stronger month after
                        month.
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto"
                >
                    <div
                        class="text-center p-8 rounded-2xl bg-gray-900/50 border border-white/5 hover:border-emerald-500/20 transition-colors"
                    >
                        <div class="text-5xl font-black text-emerald-400 mb-3">
                            53%
                        </div>
                        <p class="text-gray-300 font-medium mb-1">
                            Organic Traffic
                        </p>
                        <p class="text-gray-400 text-xs text-balance">
                            More than half of all web traffic comes from organic
                            search (BrightEdge).
                        </p>
                    </div>
                    <div
                        class="text-center p-8 rounded-2xl bg-gray-900/50 border border-white/5 hover:border-emerald-500/20 transition-colors"
                    >
                        <div class="text-5xl font-black text-emerald-400 mb-3">
                            8.5x
                        </div>
                        <p class="text-gray-300 font-medium mb-1">
                            Better Conversion
                        </p>
                        <p class="text-gray-400 text-xs text-balance">
                            SEO leads are eight times more likely to become
                            customers than cold outreach.
                        </p>
                    </div>
                    <div
                        class="text-center p-8 rounded-2xl bg-gray-900/50 border border-white/5 hover:border-emerald-500/20 transition-colors"
                    >
                        <div class="text-5xl font-black text-emerald-400 mb-3">
                            5.7x
                        </div>
                        <p class="text-gray-300 font-medium mb-1">
                            More Clicks
                        </p>
                        <p class="text-gray-400 text-xs text-balance">
                            Organic results get nearly six times more clicks
                            than paid ads.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PROCESS -->
        <section class="py-24 md:py-32 relative">
            <div
                class="absolute inset-0 bg-[url('/images/grid-pattern.svg')] bg-[length:50px_50px] opacity-[0.03] pointer-events-none"
            >
            </div>

            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
                        Not Magic. <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400"
                            >A System.</span
                        >
                    </h2>
                    <p class="text-lg text-gray-400">
                        SEO is not a collection of secret tricks. It's a
                        data-driven, transparent process tailored to your
                        industry.
                    </p>
                </div>

                <div class="max-w-4xl mx-auto space-y-6">
                    {
                        seoProcess.map((item) => (
                            <div class="flex items-start gap-6 bg-gray-900/40 border border-white/5 rounded-2xl p-6 hover:border-emerald-500/20 transition-all duration-300 group">
                                <div class="text-emerald-400 font-black text-3xl opacity-50 group-hover:opacity-100 transition-opacity">
                                    {item.step}
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold text-white mb-2">
                                        {item.title}
                                    </h3>
                                    <p class="text-gray-400 leading-relaxed">
                                        {item.description}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- PRICING -->
        <section
            id="packages"
            class="py-24 md:py-32 bg-gray-900/30 border-y border-white/5 relative overflow-hidden"
        >
            <!-- Static ambient glow — reduced blur on mobile to avoid GPU overload -->
            <div class="absolute bottom-20 -left-40 z-0 opacity-10 pointer-events-none">
                <div class="w-96 h-96 rounded-full bg-emerald-600 blur-[60px] md:blur-[120px]"></div>
            </div>

            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
                        Investment Packages
                    </h2>
                    <p class="text-lg text-gray-400">
                        A fixed-price one-time foundation — and three monthly
                        plans with concrete, transparent pricing.
                    </p>
                </div>

                <!-- ONE-TIME SETUPS -->
                <div class="text-center mb-10">
                    <span
                        class="text-xs font-bold tracking-widest text-emerald-400 uppercase"
                        >Step 1 — One-Time Foundation</span
                    >
                    <h3 class="text-2xl md:text-3xl font-bold text-white mt-2">
                        SEO Setup Packages
                    </h3>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-6"
                >
                    <!-- SEO FOUNDATION -->
                    <SpotlightCard
                        class="h-full bg-gray-900/60 border border-emerald-500/30"
                    >
                        <div class="p-6 md:p-8 h-full flex flex-col">
                            <div
                                class="inline-flex items-center gap-2 mb-4 text-xs font-bold tracking-widest text-gray-500 uppercase"
                            >
                                <span
                                    class="w-2 h-6 bg-emerald-500 rounded-full"
                                ></span>
                                One-Time Fee · Entry
                            </div>

                            <h3 class="text-2xl font-bold text-white mb-2">
                                {seoOneTime.foundation.name}
                            </h3>
                            <p
                                class="text-gray-400 text-sm mb-6 leading-relaxed"
                            >
                                {seoOneTime.foundation.tagline}
                            </p>

                            <div class="space-y-4 mb-8 flex-grow">
                                <div>
                                    <div class="text-emerald-400 text-xs font-bold uppercase tracking-wider mb-2">
                                        Technical SEO Sprint · {fmtEur(seoOneTime.technicalSprint.price)}
                                    </div>
                                    {technicalSprintIncludes.map((item) => (
                                        <div class="flex items-start gap-2 text-sm mb-1.5">
                                            <svg class="w-4 h-4 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                            <span class="text-gray-300">{item.title}</span>
                                        </div>
                                    ))}
                                </div>
                                <div>
                                    <div class="text-emerald-400 text-xs font-bold uppercase tracking-wider mb-2 pt-2">
                                        Keyword & Content Strategy · {fmtEur(seoOneTime.keywordContent.price)}
                                    </div>
                                    {keywordContentIncludes.map((item) => (
                                        <div class="flex items-start gap-2 text-sm mb-1.5">
                                            <svg class="w-4 h-4 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                            <span class="text-gray-300">{item.title}</span>
                                        </div>
                                    ))}
                                </div>
                            </div>

                            <div class="pt-6 border-t border-white/10">
                                <div class="flex items-baseline gap-2 mb-1">
                                    <span class="text-3xl font-black text-white"
                                        >{fmtEur(seoOneTime.foundation.price)}</span
                                    >
                                    <span class="text-gray-500 text-sm"
                                        >+ VAT</span
                                    >
                                </div>
                                <p class="text-xs text-emerald-400/80 mb-4">
                                    The two modules separately are {fmtEur(seoOneTime.technicalSprint.price + seoOneTime.keywordContent.price)} — cheaper as a bundle.
                                </p>
                                <a
                                    href="/contact?topic=seo-foundation"
                                    class="block w-full text-center py-3 px-6 border border-emerald-500/30 text-emerald-400 font-bold rounded-full hover:bg-emerald-500/10 transition-all"
                                >
                                    Request Foundation
                                </a>
                            </div>
                        </div>
                    </SpotlightCard>

                    <!-- COMPLEX SETUP -->
                    <SpotlightCard
                        class="h-full bg-gray-900/60 border border-purple-500/30 relative"
                    >
                        <div class="p-6 md:p-8 h-full flex flex-col">
                            <div
                                class="inline-flex items-center gap-2 mb-4 text-xs font-bold tracking-widest text-gray-500 uppercase"
                            >
                                <span
                                    class="w-2 h-6 bg-purple-500 rounded-full"
                                ></span>
                                One-Time Fee · Full
                            </div>

                            <h3 class="text-2xl font-bold text-white mb-2">
                                {seoOneTime.complex.name}
                            </h3>
                            <p
                                class="text-gray-400 text-sm mb-6 leading-relaxed"
                            >
                                {seoOneTime.complex.tagline}
                            </p>

                            <div class="space-y-3 mb-8 flex-grow">
                                {
                                    complexSetupIncludes.map((item) => (
                                        <div class="border-b border-white/5 pb-3 last:border-0">
                                            <div class="text-white font-bold text-sm flex items-center gap-2">
                                                <svg
                                                    class="w-4 h-4 text-purple-400 flex-shrink-0"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M5 13l4 4L19 7"
                                                    />
                                                </svg>
                                                {item.title}
                                            </div>
                                            <p class="text-xs text-gray-500 ml-6 mt-1">
                                                {item.description}
                                            </p>
                                        </div>
                                    ))
                                }
                            </div>

                            <div class="pt-6 border-t border-white/10">
                                <div class="flex items-baseline gap-2 mb-2">
                                    <span class="text-3xl font-black text-white"
                                        >{fmtEur(seoOneTime.complex.price)}</span
                                    >
                                    <span class="text-gray-500 text-sm"
                                        >+ VAT</span
                                    >
                                </div>
                                <p class="text-xs text-gray-500 italic mb-4">
                                    Flexible pricing — what you already have, we
                                    deduct
                                </p>
                                <a
                                    href="/contact?topic=complex-seo-setup"
                                    class="block w-full text-center py-3 px-6 border border-purple-500/40 text-purple-300 font-bold rounded-full hover:bg-purple-500/10 transition-all"
                                >
                                    Request Complex Setup
                                </a>
                            </div>
                        </div>
                    </SpotlightCard>
                </div>

                <p class="text-center text-gray-500 text-sm max-w-3xl mx-auto mb-20">
                    The SEO Foundation modules can also be ordered à la carte:
                    <strong class="text-gray-300">Technical SEO Sprint {fmtEur(seoOneTime.technicalSprint.price)}</strong> ·
                    <strong class="text-gray-300">Keyword & Content Strategy {fmtEur(seoOneTime.keywordContent.price)}</strong>.
                </p>

                <!-- MONTHLY RETAINER TIERS -->
                <div class="text-center mb-10">
                    <span
                        class="text-xs font-bold tracking-widest text-emerald-400 uppercase"
                        >Step 2 — Continuous Growth</span
                    >
                    <h3 class="text-2xl md:text-3xl font-bold text-white mt-2">
                        Monthly SEO Plans
                    </h3>
                    <p class="text-gray-400 mt-3 max-w-2xl mx-auto">
                        Three growth paces, with a minimum {SEO_MIN_MONTHS}-month
                        partnership. Every plan starts with the SEO Foundation
                        setup.
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto mb-8"
                >
                    {
