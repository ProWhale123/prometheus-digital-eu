---
// src/pages/blog/[...slug].astro
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BlogPostSchema from "../../components/BlogPostSchema.astro";
import CookieBanner from "../../components/CookieBanner.astro";
import { Image } from "astro:assets";
import SpotlightCard from "../../components/SpotlightCard.astro";
import TiltCardAstro from "../../components/TiltCardAstro.astro";
import FloatingElement from "../../components/FloatingElement.astro";

// Author image
import authorImage from "../../assets/images/arpad-bretz.jpg";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Reading time (200 words/min)
const words = (post.body || "").trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

// Related posts: match by shared tags, exclude current post
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => ({
    ...p,
    sharedTags: p.data.tags.filter((t: string) => post.data.tags.includes(t))
      .length,
  }))
  .filter((p) => p.sharedTags > 0)
  .sort((a, b) => b.sharedTags - a.sharedTags)
  .slice(0, 3);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage.src}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
  author={post.data.author}
  tags={post.data.tags}
>
  <BlogPostSchema
    title={post.data.title}
    description={post.data.description}
    pubDate={post.data.pubDate}
    updatedDate={post.data.updatedDate}
    url={`/blog/${post.slug}/`}
    author={post.data.author}
    tags={post.data.tags}
  />

  <div
    id="progress-container"
    class="fixed top-0 left-0 h-1 w-full z-[100] bg-transparent pointer-events-none"
  >
    <div
      id="progress-bar"
      class="h-full bg-gradient-to-r from-sky-400 to-cyan-300 w-0 transition-all duration-100 ease-out shadow-[0_0_10px_rgba(56,189,248,0.5)]"
    >
    </div>
  </div>

  <Header />

  <main id="main-content">
    <section
      class="relative flex items-center justify-center text-center min-h-[60vh] overflow-hidden"
    >
      <div class="absolute inset-0 z-0">
        <div
          class="parallax-bg w-full h-[120%] -translate-y-[10%] will-change-transform"
        >
          <Image
            src={post.data.heroImage}
            alt={post.data.title}
            quality="high"
            class="w-full h-full object-cover opacity-50"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>

      <div class="absolute inset-0 bg-[#0B1120]/60 backdrop-blur-sm"></div>

      <div class="container mx-auto px-6 relative z-10 pt-24 pb-12">
        <!-- Breadcrumb -->
        <Breadcrumb
          items={[
            { name: "Blog", url: "/blog" },
            { name: post.data.title, url: `/blog/${post.slug}/` },
          ]}
        />

        <div class="hero-element mb-6">
          <div class="flex flex-wrap justify-center gap-2">
            {
              post.data.tags.slice(0, 3).map((tag: string) => (
                <a
                  href={`/blog/topic/${tag.toLowerCase().replace(/\s+/g, "-").replace(/[áà]/g, "a").replace(/[éè]/g, "e").replace(/[íì]/g, "i").replace(/[óòö]/g, "o").replace(/[úùü]/g, "u").replace(/[ő]/g, "o").replace(/[ű]/g, "u").replace(/\//g, "-")}/`}
                  class="inline-block px-4 py-1.5 rounded-full bg-sky-500/10 text-sky-300 text-sm font-bold border border-sky-500/20 uppercase tracking-wider backdrop-blur-md hover:bg-sky-500/20 transition-colors"
                >
                  {tag}
                </a>
              ))
            }
          </div>
        </div>

        <h1
          class="font-black text-white mb-6 max-w-5xl mx-auto uppercase tracking-tight"
        >
          <div class="overflow-hidden py-4">
            <span
              class="hero-element block text-4xl md:text-6xl lg:text-7xl leading-[1.1]"
            >
              {post.data.title}
            </span>
          </div>
        </h1>

        <div
          class="hero-element flex flex-wrap items-center justify-center gap-6 text-gray-300 font-medium"
        >
          <div
            class="flex items-center bg-gray-900/50 px-4 py-2 rounded-full border border-white/5"
          >
            <svg
              class="w-5 h-5 mr-2 text-sky-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path></svg
            >
            <time datetime={post.data.pubDate.toISOString().split("T")[0]}>
              {
                post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              }
            </time>
          </div>
          <div
            class="flex items-center bg-gray-900/50 px-4 py-2 rounded-full border border-white/5"
          >
            <svg
              class="w-5 h-5 mr-2 text-sky-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              ></path></svg
            >
            {post.data.author}
          </div>
          <div
            class="flex items-center bg-gray-900/50 px-4 py-2 rounded-full border border-white/5"
          >
            <svg
              class="w-5 h-5 mr-2 text-sky-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path></svg
            >
            {readingTime} min read
          </div>
        </div>
      </div>
    </section>

    <article class="relative py-20 md:py-24 bg-[#0B1120] overflow-hidden">
      <div
        class="absolute inset-0 bg-[url('/images/grid-pattern.svg')] bg-[length:40px_40px] opacity-[0.03] pointer-events-none"
      >
      </div>
      <FloatingElement speed={0.1} class="top-40 -right-20 z-0 opacity-10">
        <div class="w-96 h-96 rounded-full bg-sky-500 blur-[120px]"></div>
      </FloatingElement>

      <div class="container mx-auto px-6 relative z-10">
        <div class="post-content max-w-3xl mx-auto">
          <Content />

          {
            post.data.tags.some((tag: string) =>
              tag.toLowerCase().includes("seo"),
            ) && (
              <div class="mt-16 p-8 rounded-2xl bg-gradient-to-br from-emerald-500/10 to-sky-500/10 border border-emerald-500/20 relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                  <svg
                    class="w-24 h-24 text-emerald-400"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1"
                      d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
                    />
                  </svg>
                </div>
                <div class="relative z-10">
                  <h3 class="text-2xl font-black text-white mb-4 uppercase tracking-tight">
                    Ready to Grow?
                  </h3>
                  <p class="text-gray-300 mb-6 leading-relaxed">
                    The strategy above is just the tip of the iceberg. Request a
                    free 15-minute SEO assessment where we review your website's
                    technical health and market opportunities.
                  </p>
                  <a
                    href="/contact?topic=seo-assessment"
                    class="inline-flex items-center px-6 py-3 bg-emerald-500 text-white font-bold rounded-full hover:bg-emerald-600 transition-all hover:scale-105 shadow-lg shadow-emerald-500/20"
                  >
                    Request Free SEO Audit
                    <svg
                      class="w-4 h-4 ml-2"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"
                      />
                    </svg>
                  </a>
                </div>
              </div>
            )
          }

          <!-- Author Card -->
          <aside class="mt-24 pt-12 border-t border-white/10">
            <SpotlightCard
              class="bg-gray-900/40 backdrop-blur-md"
            >
              <div
                class="p-8 md:p-10 flex flex-col md:flex-row items-center gap-8"
              >
                <div class="relative shrink-0">
                  <div
                    class="absolute inset-0 bg-gradient-to-r from-sky-500 to-cyan-300 rounded-full blur opacity-50"
                  >
                  </div>
                  <Image
                    src={authorImage}
                    alt="Arpad Bretz"
                    width={120}
                    height={120}
                    class="relative w-24 h-24 md:w-28 md:h-28 rounded-full border-2 border-white/20 shadow-xl object-cover"
                  />
                </div>
                <div class="text-center md:text-left">
                  <h3 class="text-xl font-bold text-white mb-2">
                    About the Author
                  </h3>
                  <p class="text-gray-400 leading-relaxed mb-6">
                    Founder and lead developer of Prometheus Digital. I believe
                    web development is not just about coding, but about creating
                    value.
                  </p>
                  <div
                    class="flex flex-col md:flex-row gap-4 justify-center md:justify-start"
                  >
                    <a
                      href="/contact"
                      class="inline-flex items-center justify-center px-6 py-3 bg-gradient-to-r from-sky-500 to-cyan-300 text-white rounded-full transition-all hover:shadow-[0_0_20px_rgba(14,165,233,0.4)] hover:scale-105 text-sm font-bold"
                    >
                      Let's Work Together
                    </a>
                    <a
                      href="/blog"
                      class="inline-flex items-center justify-center px-6 py-3 text-gray-400 hover:text-white transition-colors text-sm font-medium border border-white/10 hover:border-white/30 rounded-full"
                    >
                      &larr; Back to Blog
                    </a>
                  </div>
                </div>
              </div>
            </SpotlightCard>
          </aside>

          <!-- Related Posts -->
          {
            relatedPosts.length > 0 && (
              <section class="mt-16">
                <h2 class="text-2xl md:text-3xl font-black text-white mb-8 uppercase tracking-tight">
                  Related{" "}
                  <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300">
                    Articles
                  </span>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                  {relatedPosts.map((related) => (
                    <a
                      href={`/blog/${related.slug}/`}
                      class="group block bg-gray-900 border border-white/10 rounded-2xl overflow-hidden hover:border-sky-500/50 transition-all duration-300"
                    >
                      <div class="h-40 overflow-hidden">
                        <Image
                          src={related.data.heroImage}
                          alt={related.data.title}
                          width={400}
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                      </div>
                      <div class="p-5">
                        <time
                          datetime={
                            related.data.pubDate.toISOString().split("T")[0]
                          }
                          class="text-xs text-sky-400 font-bold uppercase tracking-wider"
                        >
                          {related.data.pubDate.toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "short",
                            day: "numeric",
                          })}
                        </time>
                        <h3 class="text-lg font-bold text-white mt-2 leading-snug group-hover:text-sky-300 transition-colors line-clamp-2">
                          {related.data.title}
                        </h3>
                      </div>
                    </a>
                  ))}
                </div>
              </section>
            )
          }
        </div>
      </div>
    </article>
  </main>

  <Footer />
  <CookieBanner />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function initBlogPost() {
    // Kill all page-level ScrollTriggers to prevent accumulation on View Transitions
    ScrollTrigger.getAll().forEach(t => t.kill());

    // Elements start visible — animation enhances progressively (no LCP blocking)

    const updateProgress = () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const bar = document.getElementById("progress-bar");
      if (bar) bar.style.width = scrolled + "%";
    };
    window.removeEventListener("scroll", updateProgress);
    window.addEventListener("scroll", updateProgress);

    const tl = gsap.timeline({ delay: 0.2 });
    tl.from(".hero-element", {
      y: 20,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power4.out",
    });

    gsap.to(".parallax-bg", {
      yPercent: 20,
      ease: "none",
      scrollTrigger: {
        trigger: "main",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
    });
  }

  // Only use astro:page-load (fires on initial load too) — prevents double init
  document.addEventListener("astro:page-load", initBlogPost);
</script>

<style is:global>
  .post-content {
    color: #cbd5e1;
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .post-content h2 {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 800;
    margin-top: 3em;
    margin-bottom: 1em;
    letter-spacing: -0.02em;
    position: relative;
    display: inline-block;
  }
  .post-content h2::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 60px;
    height: 3px;
    background: linear-gradient(to right, #38bdf8, transparent);
  }

  .post-content h3 {
    color: #e2e8f0;
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5em;
    margin-bottom: 0.8em;
  }

  .post-content h4 {
    color: #e2e8f0;
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

  .post-content p {
    margin-bottom: 1.5em;
  }
  .post-content strong {
    color: #ffffff;
    font-weight: 700;
  }

  .post-content a {
    color: #f3f5f6;
    text-decoration: none;
    border-bottom: 1px solid rgba(56, 189, 248, 0.5);
    transition: all 0.2s ease-in-out;
  }
  .post-content a:hover {
    color: #7dd3fc;
    border-bottom-color: #7dd3fc;
  }

  .post-content ul {
    list-style: none;
    margin: 2em 0;
    padding: 0;
  }
  .post-content ol {
    margin: 2em 0;
    padding: 0;
    counter-reset: list-counter;
    list-style: none;
  }
  .post-content ol li {
    counter-increment: list-counter;
  }
  .post-content ol li::before {
    content: counter(list-counter) ".";
    color: #38bdf8;
    font-weight: bold;
    font-size: 1.1em;
    position: absolute;
    left: 0;
    top: 0;
  }
  .post-content li {
    position: relative;
    padding-left: 1.5em;
    margin-bottom: 0.8em;
    color: #cbd5e1;
  }
  .post-content ul li::before {
    content: "\2022";
    color: #38bdf8;
    font-weight: bold;
    font-size: 1.5em;
    position: absolute;
    left: 0;
    top: -5px;
  }

  .post-content blockquote {
    margin: 3em 0;
    padding: 2em;
    background: rgba(255, 255, 255, 0.03);
    border-left: 4px solid #38bdf8;
    border-radius: 0 1rem 1rem 0;
    font-style: italic;
    font-size: 1.25rem;
    color: #f1f5f9;
    position: relative;
  }

  .post-content pre {
    background: #1e293b !important;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin: 2em 0;
    padding: 1.5em;
    overflow-x: auto;
  }

  /* Tables for comparison content */
  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
    font-size: 0.95rem;
  }
  .post-content thead th {
    background: rgba(56, 189, 248, 0.1);
    color: #ffffff;
    font-weight: 700;
    text-align: left;
    padding: 1em;
    border-bottom: 2px solid rgba(56, 189, 248, 0.3);
  }
  .post-content tbody td {
    padding: 0.8em 1em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: #cbd5e1;
  }
  .post-content tbody tr:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  /* FAQ sections */
  .post-content details {
    margin: 1em 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .post-content details[open] {
    border-color: rgba(56, 189, 248, 0.3);
  }
  .post-content summary {
    padding: 1.2em 1.5em;
    background: rgba(255, 255, 255, 0.03);
    color: #ffffff;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .post-content summary::after {
    content: "+";
    color: #38bdf8;
    font-size: 1.5em;
    font-weight: 300;
    transition: transform 0.3s ease;
  }
  .post-content details[open] summary::after {
    transform: rotate(45deg);
  }
  .post-content details > div,
  .post-content details > p:not(summary) {
    padding: 1em 1.5em 1.5em;
  }

  /* CTA button style for inline links */
  .post-content .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1em 2.5em;
    margin-top: 1em;
    background: linear-gradient(to right, #0ea5e9, #22d3ee);
    color: #ffffff !important;
    font-weight: 700;
    border-radius: 9999px;
    border-bottom: none !important;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.9rem;
  }
  .post-content .cta-button:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px rgba(14, 165, 233, 0.4);
    color: #ffffff !important;
  }
</style>
