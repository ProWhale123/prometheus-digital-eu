---
// src/pages/blog/topic/[tag].astro
// Dynamic tag pages for blog topic clusters

import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import Contact from "../../../components/Contact.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import CookieBanner from "../../../components/CookieBanner.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import TiltCardAstro from "../../../components/TiltCardAstro.astro";
import FloatingElement from "../../../components/FloatingElement.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");

    // Collect all unique tags
    const allTags = new Set<string>();
    posts.forEach((post) => {
        post.data.tags.forEach((tag: string) => allTags.add(tag));
    });

    return Array.from(allTags).map((tag) => {
        const tagSlug = tag
            .toLowerCase()
            .replace(/\s+/g, "-")
            .replace(/[áà]/g, "a")
            .replace(/[éè]/g, "e")
            .replace(/[íì]/g, "i")
            .replace(/[óòö]/g, "o")
            .replace(/[úùü]/g, "u")
            .replace(/[ő]/g, "o")
            .replace(/[ű]/g, "u")
            .replace(/\//g, "-");

        const filteredPosts = posts
            .filter((post) => post.data.tags.includes(tag))
            .sort(
                (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
            );

        return {
            params: { tag: tagSlug },
            props: { tag, posts: filteredPosts },
        };
    });
}

const { tag, posts } = Astro.props;
---

<Layout
    title={`${tag} Articles – Prometheus Digital Blog`}
    description={`Read our latest ${tag} articles. Tips, guides and expert advice for businesses.`}
    noindex={true}
>
    <Header />

    <main id="main-content" class="overflow-hidden">
        <section class="pt-32 pb-16 bg-[#0B1120] relative">
            <div
                class="absolute inset-0 bg-[url('/images/grid-pattern.svg')] bg-[length:50px_50px] opacity-[0.03] pointer-events-none"
            >
            </div>

            <Breadcrumb
                items={[
                    { name: "Blog", url: "/blog" },
                    { name: tag, url: `/blog/topic/${Astro.params.tag}` },
                ]}
            />

            <div class="container mx-auto px-6 relative z-10 mt-4">
                <div class="max-w-4xl">
                    <span
                        class="inline-block px-4 py-1.5 rounded-full bg-sky-500/10 text-sky-300 text-sm font-bold border border-sky-500/20 uppercase tracking-wider mb-6"
                    >
                        {tag}
                    </span>
                    <h1
                        class="text-4xl md:text-6xl font-black text-white uppercase tracking-tight mb-4"
                    >
                        {tag}
                        <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300"
                            >Articles</span
                        >
                    </h1>
                    <p class="text-lg text-gray-400 max-w-2xl">
                        {posts.length} article{posts.length !== 1 ? "s" : ""} about <strong class="text-white"
                            >{tag}</strong
                        >. Explore our latest tips and guides.
                    </p>
                </div>
            </div>
        </section>

        <section class="py-16 md:py-24 bg-[#0B1120] relative">
            <FloatingElement speed={-0.2} class="top-20 right-0 z-0 opacity-10">
                <div class="w-96 h-96 rounded-full bg-cyan-500 blur-[120px]">
                </div>
            </FloatingElement>

            <div class="container mx-auto px-6 relative z-10">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10 max-w-6xl mx-auto"
                >
                    {
                        posts.map((post) => (
                            <article class="blog-card">
                                <TiltCardAstro
                                    class="h-full bg-transparent"
                                >
                                    <a
                                        href={`/blog/${post.slug}/`}
                                        class="block group h-full bg-gray-900 border border-white/10 rounded-3xl overflow-hidden hover:border-sky-500/50 transition-all duration-500 shadow-xl"
                                    >
                                        <div class="h-60 overflow-hidden relative">
                                            <div class="absolute inset-0 bg-sky-900/0 group-hover:bg-sky-900/20 transition-colors duration-500 z-10" />
                                            <Image
                                                src={post.data.heroImage}
                                                alt={post.data.title}
                                                width={800}
                                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                            />

                                            <div class="absolute top-4 left-4 z-20 bg-gray-900/80 backdrop-blur-md px-3 py-1 rounded-full border border-white/10">
                                                <time
                                                    datetime={
                                                        post.data.pubDate
                                                            .toISOString()
                                                            .split("T")[0]
                                                    }
                                                    class="text-xs font-bold text-sky-400 uppercase tracking-wider"
                                                >
                                                    {post.data.pubDate.toLocaleDateString(
                                                        "en-US",
                                                        {
                                                            year: "numeric",
                                                            month: "short",
                                                            day: "numeric",
                                                        },
                                                    )}
                                                </time>
                                            </div>
                                        </div>

                                        <div class="p-8 flex flex-col h-[calc(100%-15rem)]">
                                            <div class="flex flex-wrap gap-2 mb-4">
                                                {post.data.tags
                                                    .slice(0, 3)
                                                    .map((t: string) => (
                                                        <span
                                                            class={`text-xs font-bold uppercase tracking-widest px-2 py-1 rounded border ${t === tag ? "text-sky-400 border-sky-500/30 bg-sky-500/10" : "text-gray-500 border-white/10"}`}
                                                        >
                                                            {t}
                                                        </span>
                                                    ))}
                                            </div>

                                            <h2 class="text-2xl font-bold text-white mb-4 leading-tight group-hover:text-sky-300 transition-colors">
                                                {post.data.title}
                                            </h2>

                                            <p class="text-gray-400 mb-6 flex-grow line-clamp-3 leading-relaxed">
                                                {post.data.description}
                                            </p>

                                            <div class="flex items-center text-sky-400 font-bold text-sm uppercase tracking-wider group/link mt-auto">
                                                <span class="mr-2 group-hover/link:mr-4 transition-all">
                                                    Read More
                                                </span>
                                                <svg
                                                    class="w-4 h-4"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                                    />
                                                </svg>
                                            </div>
                                        </div>
                                    </a>
                                </TiltCardAstro>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <Contact />
    </main>

    <Footer />
    <CookieBanner />
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function animateTagPage() {
        // Kill all page-level ScrollTriggers to prevent accumulation on View Transitions
        ScrollTrigger.getAll().forEach(t => t.kill());

        const cards = document.querySelectorAll(".blog-card");
        gsap.fromTo(
            cards,
            { opacity: 0, y: 40 },
            {
                opacity: 1,
                y: 0,
                duration: 0.8,
                stagger: 0.1,
                ease: "power3.out",
            },
        );
    }

    // Only use astro:page-load (fires on initial load too) — prevents double init
    document.addEventListener("astro:page-load", animateTagPage);
</script>
