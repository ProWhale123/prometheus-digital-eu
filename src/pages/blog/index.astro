---
// src/pages/blog/index.astro
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Contact from "../../components/Contact.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import CookieBanner from "../../components/CookieBanner.astro";

// Interactive elements
import TiltCardAstro from "../../components/TiltCardAstro.astro";
import FloatingElement from "../../components/FloatingElement.astro";

// Background
import blogImage from "../../assets/images/blog-background.jpg";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Reading time calculator (200 words/min)
function getReadingTime(body: string): number {
    const words = body.trim().split(/\s+/).length;
    return Math.max(1, Math.ceil(words / 200));
}

// Collect all unique tags with post counts
const tagMap = new Map<string, number>();
posts.forEach((post) => {
    post.data.tags.forEach((tag: string) => {
        tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
    });
});
const popularTags = Array.from(tagMap.entries())
    .sort((a, b) => b[1] - a[1])
    .slice(0, 12);
---

<Layout
    title="Blog — Web Development, SEO and Digital Strategy | Prometheus Digital"
    description="Expert articles on web development, SEO, UI/UX and digital marketing. Practical tips and guides for businesses from the Prometheus Digital team."
>
    <Header />

    <main id="main-content" class="overflow-hidden">
        <section
            class="relative h-[50vh] min-h-[400px] flex items-center justify-center text-center overflow-hidden"
        >
            <div class="absolute inset-0 z-0">
                <div
                    class="parallax-bg w-full h-[120%] -translate-y-[10%] will-change-transform"
                >
                    <Image
                        src={blogImage}
                        alt="Prometheus Digital Blog — Web Development, SEO and Digital Strategy"
                        class="w-full h-full object-cover opacity-60"
                        widths={[640, 1024, 1440, 1920]}
                        sizes="100vw"
                        quality="mid"
                        loading="eager"
                        fetchpriority="high"
                    />
                </div>
            </div>
            <div
                class="absolute inset-0 bg-[#0B1120]/70 backdrop-blur-[2px] z-10"
            >
            </div>

            <div class="container mx-auto px-6 relative z-10 pt-10">
                <Breadcrumb items={[{ name: "Blog", url: "/blog" }]} />

                <h1
                    class="font-black text-white uppercase tracking-tighter mb-4 mt-4"
                >
                    <div class="overflow-hidden py-2">
                        <span
                            class="reveal-text block text-4xl md:text-6xl text-gray-300"
                        >
                            THOUGHTS &
                        </span>
                    </div>
                    <div class="overflow-hidden py-4">
                        <span
                            class="reveal-text block text-5xl md:text-7xl text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300"
                        >
                            INSIGHTS
                        </span>
                    </div>
                </h1>
                <p
                    class="reveal-desc max-w-2xl mx-auto text-lg md:text-xl text-gray-300 font-light"
                >
                    Your digital compass. Expert articles on web development, SEO and
                    marketing for businesses.
                </p>
            </div>
        </section>

        <!-- Tag Filter Bar -->
        <section
            class="bg-[#0B1120] border-b border-white/5 py-6 sticky top-16 z-30"
        >
            <div class="container mx-auto px-6">
                <div
                    class="flex flex-wrap items-center gap-3 max-w-6xl mx-auto"
                >
                    <span
                        class="text-gray-500 text-sm font-bold uppercase tracking-wider mr-2"
                        >Topics:</span
                    >
                    {
                        popularTags.map(([tag, count]) => {
                            const tagSlug = tag
                                .toLowerCase()
                                .replace(/\s+/g, "-")
                                .replace(/[áà]/g, "a")
                                .replace(/[éè]/g, "e")
                                .replace(/[íì]/g, "i")
                                .replace(/[óòö]/g, "o")
                                .replace(/[úùü]/g, "u")
                                .replace(/[ő]/g, "o")
                                .replace(/[ű]/g, "u")
                                .replace(/\//g, "-");
                            return (
                                <a
                                    href={`/blog/topic/${tagSlug}/`}
                                    class="text-xs font-bold text-gray-400 uppercase tracking-wider bg-white/5 hover:bg-sky-500/10 hover:text-sky-400 px-3 py-1.5 rounded-full border border-white/10 hover:border-sky-500/20 transition-all"
                                >
                                    {tag}{" "}
                                    <span class="text-gray-600 ml-1">
                                        ({count})
                                    </span>
                                </a>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        <section class="py-24 md:py-32 bg-[#0B1120] relative">
            <FloatingElement speed={-0.2} class="top-20 right-0 z-0 opacity-10">
                <div class="w-96 h-96 rounded-full bg-cyan-500 blur-[120px]">
                </div>
            </FloatingElement>

            <div class="container mx-auto px-6 relative z-10">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10 max-w-6xl mx-auto"
                >
                    {
                        sortedPosts.map((post, index) => (
                            <article class="blog-card opacity-0 translate-y-12">
                                <TiltCardAstro
                                    class="h-full bg-transparent"
                                >
                                    <a
                                        href={`/blog/${post.slug}/`}
                                        class="block group h-full bg-gray-900 border border-white/10 rounded-3xl overflow-hidden hover:border-sky-500/50 transition-all duration-500 shadow-xl"
                                    >
                                        <div class="h-60 overflow-hidden relative">
                                            <div class="absolute inset-0 bg-sky-900/0 group-hover:bg-sky-900/20 transition-colors duration-500 z-10" />
                                            <Image
                                                src={post.data.heroImage}
                                                alt={post.data.title}
                                                width={800}
                                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                            />

                                            <div class="absolute top-4 left-4 z-20 flex gap-2">
                                                <div class="bg-gray-900/80 backdrop-blur-md px-3 py-1 rounded-full border border-white/10">
                                                    <time
                                                        datetime={
                                                            post.data.pubDate
                                                                .toISOString()
                                                                .split("T")[0]
                                                        }
                                                        class="text-xs font-bold text-sky-400 uppercase tracking-wider"
                                                    >
                                                        {post.data.pubDate.toLocaleDateString(
                                                            "en-US",
                                                            {
                                                                year: "numeric",
                                                                month: "short",
                                                                day: "numeric",
                                                            },
                                                        )}
                                                    </time>
                                                </div>
                                                <div class="bg-gray-900/80 backdrop-blur-md px-3 py-1 rounded-full border border-white/10">
                                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                                                        {getReadingTime(post.body || "")} min read
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="p-8 flex flex-col h-[calc(100%-15rem)]">
                                            <div class="flex flex-wrap gap-2 mb-4">
                                                {post.data.tags
                                                    .slice(0, 3)
                                                    .map((tag: string) => (
                                                        <span class="text-xs font-bold text-gray-500 uppercase tracking-widest border border-white/10 px-2 py-1 rounded">
                                                            {tag}
                                                        </span>
                                                    ))}
                                            </div>

                                            <h2 class="text-2xl font-bold text-white mb-4 leading-tight group-hover:text-sky-300 transition-colors">
                                                {post.data.title}
                                            </h2>

                                            <p class="text-gray-400 mb-6 flex-grow line-clamp-3 leading-relaxed">
                                                {post.data.description}
                                            </p>

                                            <div class="flex items-center text-sky-400 font-bold text-sm uppercase tracking-wider group/link mt-auto">
                                                <span class="mr-2 group-hover/link:mr-4 transition-all">
                                                    Read More
                                                </span>
                                                <svg
                                                    class="w-4 h-4"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                                    />
                                                </svg>
                                            </div>
                                        </div>
                                    </a>
                                </TiltCardAstro>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <Contact />
    </main>

    <Footer />
    <CookieBanner />
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function animateBlogList() {
        // Kill all page-level ScrollTriggers to prevent accumulation on View Transitions
        ScrollTrigger.getAll().forEach(t => t.kill());

        // Elements start visible — animation enhances progressively (no LCP blocking)
        const tl = gsap.timeline({ delay: 0.2 });
        tl.from(".reveal-text", {
            y: 80,
            opacity: 0,
            duration: 1.2,
            stagger: 0.15,
            ease: "power4.out",
        }).from(
            ".reveal-desc",
            {
                y: 40,
                opacity: 0,
                duration: 1,
                ease: "power3.out",
            },
            "-=0.8",
        );

        gsap.to(".parallax-bg", {
            yPercent: 20,
            ease: "none",
            scrollTrigger: {
                trigger: "header",
                start: "top top",
                end: "bottom top",
                scrub: true,
            },
        });

        const cards = document.querySelectorAll(".blog-card");
        ScrollTrigger.batch(cards, {
            onEnter: (batch) =>
                gsap.to(batch, {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    stagger: 0.15,
                    ease: "power3.out",
                    overwrite: true,
                }),
            start: "top 90%",
        });
    }

    // Only use astro:page-load (fires on initial load too) — prevents double init
    document.addEventListener("astro:page-load", animateBlogList);
</script>
