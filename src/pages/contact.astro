---
// src/pages/contact.astro
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactSection from "../components/Contact.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<Layout
    title="Contact - Prometheus Digital"
    description="Contact the Prometheus Digital team. Request a quote or ask your questions."
>
    <Header />

    <main id="main-content">
        <!-- Page Hero Section -->
        <section class="pt-40 pb-20 bg-gray-900/40">
            <div class="container mx-auto px-6 text-center">
                <Breadcrumb
                    items={[{ name: "Contact", url: "/contact" }]}
                />
                <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">
                    Get in <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300"
                        >Touch</span
                    >
                </h1>
                <p class="max-w-3xl mx-auto text-lg text-gray-300">
                    Ready to reach the top in the digital space? Write to us,
                    call us, or visit us for a coffee. We look forward to
                    hearing your ideas!
                </p>
            </div>
        </section>

        <!-- Reuse Contact Section (Form + Details) -->
        <ContactSection />
    </main>

    <Footer />

    <script>
        // Pre-fills the form subject from CTA params ?topic= / ?package=&price=
        function prefillContactForm() {
            const params = new URLSearchParams(window.location.search);
            const topic = params.get("topic");
            const pkg = params.get("package");
            const price = params.get("price");

            const subjectEl = document.querySelector('form[name="contact"] input[name="subject"]');
            const msgEl = document.querySelector('form[name="contact"] textarea[name="message"]');
            if (!subjectEl) return;

            const labels = {
                "seo-assessment": "Free SEO assessment",
                "seo-foundation": "SEO Foundation — quote request",
                "complex-seo-setup": "Complex SEO Setup — quote request",
                "seo-local": "SEO Local monthly plan — quote request",
                "seo-growth": "SEO Growth monthly plan — quote request",
                "seo-dominance": "SEO Dominance monthly plan — quote request",
                "geo-audit": "GEO/AI Visibility Audit — quote request",
                "geo-setup": "GEO/AI Setup — quote request",
                "geo-combo": "GEO/AI Audit + Setup bundle — quote request",
                "geo-monitoring": "GEO/AI Monthly Monitoring — quote request",
                "geo-fine-tuning": "GEO/AI Fine-tuning + Monitoring — quote request",
                "maintenance-essential": "Maintenance — Essential plan",
                "maintenance-standard": "Maintenance — Standard plan",
                "maintenance-business": "Maintenance — Business plan",
                "maintenance-premium": "Maintenance — Premium plan",
            };

            let subject = "";
            if (pkg === "custom") {
                subject = "Custom website configuration — quote request";
                const n = parseInt(price || "", 10);
                if (!isNaN(n)) subject += ` (approx. €${new Intl.NumberFormat("en-IE").format(n)})`;
            } else if (topic) {
                subject = labels[topic] || (topic.charAt(0).toUpperCase() + topic.slice(1).replace(/-/g, " "));
            }

            if (subject && !subjectEl.value) {
                subjectEl.value = subject;
                if (msgEl && !msgEl.value) {
                    msgEl.value = `I'd like to ask about: ${subject}.\n\n`;
                }
                try { msgEl && msgEl.focus(); } catch (e) {}
            }
        }
        document.addEventListener("astro:page-load", prefillContactForm);
    </script>
</Layout>
