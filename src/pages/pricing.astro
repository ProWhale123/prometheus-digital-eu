<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function animatePricing() {
        // Kill all page-level ScrollTriggers to prevent accumulation on View Transitions
        ScrollTrigger.getAll().forEach(t => t.kill());

        // Kill any competing tweens from previous invocations (HMR / view transitions)
        gsap.set(".reveal-text", { y: 80, opacity: 0 });
        gsap.set(".reveal-desc", { y: 40, opacity: 0 });

        const tl = gsap.timeline({ delay: 0.05 });
        tl.to(".reveal-text", {
            y: 0, opacity: 1, duration: 0.6, stagger: 0.08, ease: "power4.out",
        }).to(
            ".reveal-desc",
            { y: 0, opacity: 1, duration: 0.5, stagger: 0.1, ease: "power3.out" },
            "-=0.4",
        );

        // Skip parallax on mobile — scrub-based scroll animation is GPU-heavy
        if (!window.matchMedia('(pointer: coarse)').matches) {
            gsap.to(".parallax-bg", {
                yPercent: 20,
                ease: "none",
                scrollTrigger: {
                    trigger: "header",
                    start: "top top",
                    end: "bottom top",
                    scrub: true,
                },
            });
        }
    }

    // Only use astro:page-load (fires on initial load too) — prevents double init
    document.addEventListener("astro:page-load", animatePricing);
</script>
