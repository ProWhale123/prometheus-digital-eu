                    </div>

                    {/* GROWTH */}
                    <div
                        class="bg-sky-500/5 border border-sky-500/30 p-8 rounded-3xl flex flex-col relative scale-105 shadow-2xl shadow-sky-500/10"
                    >
                        <div
                            class="absolute -top-4 left-1/2 -translate-x-1/2 bg-sky-500 text-white text-[10px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full"
                        >
                            Most Popular
                        </div>
                        <div
                            class="text-sky-400 font-bold text-xs tracking-widest uppercase mb-4"
                        >
                            Growth
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">
                            Business Authority
                        </h3>
                        <p class="text-gray-500 text-sm mb-6">
                            For service providers and experts who want to
                            dominate the market.
                        </p>
                        <div class="text-3xl font-black text-white mb-8">
                            €1,790 <span
                                class="text-xs text-gray-500 font-normal"
                                >+ VAT</span
                            >
                        </div>

                        <ul class="space-y-4 mb-10 flex-grow">
                            <li class="flex items-center text-sm text-gray-300">
                                <svg
                                    class="w-4 h-4 text-sky-400 mr-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                Professional CMS & Blog
                            </li>
                            <li class="flex items-center text-sm text-gray-300">
                                <svg
                                    class="w-4 h-4 text-sky-400 mr-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                5 Subpages
                            </li>
                            <li class="flex items-center text-sm text-gray-300">
                                <svg
                                    class="w-4 h-4 text-sky-400 mr-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
