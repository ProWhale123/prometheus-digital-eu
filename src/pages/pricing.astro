                            </li>
                            <li class="flex items-start text-gray-300">
                                <svg
                                    class="w-4 h-4 text-emerald-400 mr-3 mt-0.5 flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
