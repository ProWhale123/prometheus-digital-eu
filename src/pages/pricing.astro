            <div class="absolute top-20 -right-40 z-0 opacity-5 pointer-events-none">
                <div class="w-[500px] h-[500px] rounded-full bg-emerald-600 blur-[60px] md:blur-[150px]"></div>
            </div>

            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center max-w-3xl mx-auto mb-12">
                    <span
                        class="text-emerald-400 font-bold uppercase tracking-widest text-xs"
