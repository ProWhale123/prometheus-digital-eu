                        <div
                            class="text-purple-400 font-bold text-xs tracking-widest uppercase mb-4"
                        >
                            Premium
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">
                            Elite Digital
                        </h3>
                        <p class="text-gray-500 text-sm mb-6">
                            Everything included. For international markets, with
                            custom design.
                        </p>
                        <div class="text-3xl font-black text-white mb-8">
                            From €2,990 <span
                                class="text-xs text-gray-500 font-normal"
                                >+ VAT</span
                            >
                        </div>

                        <ul class="space-y-4 mb-10 flex-grow">
                            <li class="flex items-center text-sm text-gray-300">
                                <svg
                                    class="w-4 h-4 text-purple-400 mr-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                Custom UX/UI Design
                            </li>
                            <li class="flex items-center text-sm text-gray-300">
                                <svg
                                    class="w-4 h-4 text-purple-400 mr-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
