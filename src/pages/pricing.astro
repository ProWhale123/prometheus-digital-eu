                                Cinematic Animations
                            </li>
                            <li class="flex items-center text-sm text-gray-300">
                                <svg
                                    class="w-4 h-4 text-purple-400 mr-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                Multilingual (i18n) Support
                            </li>
                            <li class="flex items-center text-sm text-gray-300">
                                <svg
                                    class="w-4 h-4 text-purple-400 mr-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
