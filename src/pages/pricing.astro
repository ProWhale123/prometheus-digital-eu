                        RECOMMENDED
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">
                        Annual "Peace of Mind" Package
                    </h3>
                    <div class="text-4xl font-black text-sky-400 mb-6">
                        €120 <span class="text-lg text-gray-500 font-normal"
                            >/ year</span
                        >
                    </div>

                    <ul
                        class="text-gray-300 space-y-3 mb-8 text-left max-w-sm mx-auto"
                    >
                        <li class="flex items-center">
                            <svg
                                class="w-5 h-5 text-green-400 mr-3"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >Premium Hosting & Domain
                        </li>
                        <li class="flex items-center">
                            <svg
                                class="w-5 h-5 text-green-400 mr-3"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
