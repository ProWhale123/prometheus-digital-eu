---

<Layout
    title="Our Work — Client Projects and Demo Sites | Prometheus Digital"
    description="Check out the custom websites built by Prometheus Digital: real client projects and industry demo sites showcasing our expertise."
>
    <Header />

    <main id="main-content" class="overflow-hidden">
        <section
            class="relative h-[60vh] min-h-[500px] flex items-center justify-center text-center overflow-hidden"
        >
            <div class="absolute inset-0 z-0">
                <div
                    class="parallax-bg w-full h-[120%] -translate-y-[10%] will-change-transform"
                >
                    <Image
                        src={portfolioImage}
                        alt="Prometheus Digital website portfolio and references"
                        class="w-full h-full object-cover opacity-60"
                        widths={[640, 1024, 1440, 1920]}
                        sizes="100vw"
                        quality="mid"
                        loading="eager"
                        fetchpriority="high"
                    />
                </div>
            </div>

            <div
                class="absolute inset-0 bg-[#0B1120]/60 backdrop-blur-[2px] z-10"
            >
            </div>

            <div class="container mx-auto px-6 relative z-20 pt-20">
                <Breadcrumb items={[{ name: "Our Work", url: "/works" }]} />
                <h1
                    class="font-black text-white uppercase tracking-tighter mb-6"
                >
                    <div class="overflow-hidden py-4">
                        <span
                            class="reveal-text block text-4xl md:text-7xl"
                        >
                            WHAT WE ARE
                        </span>
                    </div>
                    <div class="overflow-hidden">
                        <span
                            class="reveal-text block text-5xl md:text-8xl text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300 pb-2"
                        >
                            PROUD OF
                        </span>
                    </div>
                </h1>

                <p
                    class="reveal-desc max-w-2xl mx-auto text-lg md:text-xl text-gray-300 font-light"
                >
                    Real client projects and industry demos — see the websites
                    we build, and find inspiration for yours!
                </p>
            </div>

            <div
                class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-20 animate-bounce opacity-50"
            >
                <span
                    class="text-xs font-mono text-gray-400 uppercase tracking-widest"
                    >Scroll</span
                >
                <svg
                    class="w-5 h-5 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg
                >
            </div>
        </section>

        <!-- Client Projects -->
        <section class="relative py-24 md:py-32 bg-[#0B1120]">
            <FloatingElement speed={0.2} class="top-20 -left-20 z-0 opacity-20">
                <div class="w-96 h-96 rounded-full bg-sky-500 blur-[100px]">
                </div>
            </FloatingElement>
            <div
                class="absolute inset-0 bg-[url('/images/grid-pattern.svg')] bg-[length:50px_50px] opacity-[0.03] pointer-events-none"
            >
            </div>

            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center mb-16">
                    <span class="text-sm font-bold text-sky-400 uppercase tracking-widest mb-4 block">Real clients, real results</span>
                    <h2 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tight">
                        Client <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-cyan-300">Projects</span>
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">
                    {
                        clientProjects.map((project, index) => (
                            <div
                                class={`project-card ${index % 2 !== 0 ? "md:translate-y-16" : ""}`}
                            >
                                <TiltCardAstro
                                    class="h-full bg-transparent"
                                >
                                    <a
                                        href={project.liveUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
