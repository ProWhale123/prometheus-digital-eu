<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function animateWorks() {
        // Kill all page-level ScrollTriggers to prevent accumulation on View Transitions
        ScrollTrigger.getAll().forEach(t => t.kill());

        gsap.set(".reveal-text", { y: 80, opacity: 0 });
        gsap.set(".reveal-desc", { y: 40, opacity: 0 });

        const tl = gsap.timeline({ delay: 0.05 });
        tl.to(".reveal-text", {
            y: 0, opacity: 1, duration: 0.6, stagger: 0.08, ease: "power4.out",
        }).to(
            ".reveal-desc",
            { y: 0, opacity: 1, duration: 0.5, ease: "power3.out" },
            "-=0.8",
        );

        // 2. Parallax Background
        gsap.to(".parallax-bg", {
            yPercent: 20,
            ease: "none",
            scrollTrigger: {
                trigger: "header",
                start: "top top",
                end: "bottom top",
                scrub: true,
            },
        });

        // 3. Grid Fade-In
        const cards = document.querySelectorAll(".project-card");
        cards.forEach((card, i) => {
            gsap.fromTo(
                card,
                { y: 100, opacity: 0 },
                {
                    y: 0,
                    opacity: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: card,
                        start: "top 85%",
                    },
                },
            );
        });
    }

    // Only use astro:page-load (fires on initial load too) — prevents double init
    document.addEventListener("astro:page-load", animateWorks);
</script>
